node_modules/
tsc-out/
*.log
.DS_Store
.env
.turbo/
storybook-static/

# Generated by `pnpm create:react` — apps/* are throwaway scaffolds, never
# committed. Keep the placeholder that makes the workspace glob resolvable
# on a fresh clone before any app has been generated.
apps/*
!apps/.gitkeep

# Built CLI output for the scaffolder — rebuilt via `pnpm --filter @lumen/create-app build`,
# unlike packages/tokens/dist (which IS committed; tokens has no build-before-use requirement).
packages/create-app/dist/
