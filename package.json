{
  "name": "lumen-ai-design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Lumen AI Design System — single source of truth for design tokens, components, layout primitives, and enterprise patterns used across all Lumen SaaS products.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "scripts": {
    "build": "pnpm --filter @lumen/tokens build",
    "dev": "pnpm --filter @lumen/storybook storybook",
    "start": "pnpm --filter @lumen/storybook build-storybook && pnpm dlx serve packages/storybook/storybook-static",
    "typecheck": "pnpm --filter \"./packages/**\" --if-present run typecheck",
    "test": "pnpm --filter \"./packages/**\" --if-present run test",
    "storybook": "pnpm --filter @lumen/storybook storybook",
    "build-storybook": "pnpm --filter @lumen/storybook build-storybook",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "create:react": "pnpm --filter @lumen/create-app start",
    "create:react:dev": "pnpm --filter @lumen/create-app dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint-plugin-jsx-a11y": "^6.9.0"
  }
}
