{
  "name": "lumen-design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Lumen Design System — single source of truth for design tokens, components, layout primitives, and enterprise patterns used across all Lumen SaaS products.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "scripts": {
    "build": "pnpm --filter @lumen/tokens build",
    "dev": "pnpm --filter @lumen/storybook storybook",
    "start": "pnpm --filter @lumen/storybook build-storybook && pnpm dlx serve packages/storybook/storybook-static",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "storybook": "pnpm --filter @lumen/storybook storybook",
    "build-storybook": "pnpm --filter @lumen/storybook build-storybook",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint-plugin-jsx-a11y": "^6.9.0"
  }
}
